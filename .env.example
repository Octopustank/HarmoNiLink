# HarmoNiLink Signing Environment
# Copy to .env and fill in real values
# .env is gitignored — never commit passwords

SIGN_KEYSTORE_PASS=
SIGN_KEY_ALIAS=HarmoNiLink-Release
SIGN_KEYSTORE_FILE=./signing/HarmoNiLink.p12
SIGN_CERT_FILE=./signing/Release_Cert.cer
SIGN_PROFILE_FILE=./signing/NiLink_ProfileRelease.p7b
SIGN_ALG=SHA256withECDSA
SIGN_COMPAT_VERSION=23
